{
  "name": "@kth/canvas-api",
  "version": "3.0.0-0",
  "description": " Functions for communicating with Canvas LMS",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "format": "prettier --write .",
    "test": "npm run test:lint && ava",
    "test:lint": "eslint src && prettier --check .",
    "build": "npm test"
  },
  "exports": {
    ".": {
