  },
  "license": "MIT",
  "dependencies": {
    "@hapi/joi": "^15.1.0",
    "debug": "^4.1.1",
    "form-data": "^2.5.0",
    "got": "^11.8.1",
    "query-string": "^6.13.1"
  },
  "devDependencies": {
    "ajv": "^6.12.2",
    "ava": "^3.9.0",
    "create-test-server": "^3.0.1",
    "dotenv": "^8.2.0",
    "eslint": "^7.19.0",
    "ora": "^5.0.0",
    "prettier": "^2.2.1",
    "tempy": "^0.3.0"
  }
